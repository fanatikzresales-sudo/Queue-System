{
  "appId": "com.frqueue.optimizer",
  "appName": "FR Queue Optimizer",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#0d1117",
      "showSpinner": false
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon"
    }
  },
  "android": {
    "allowMixedContent": false
  },
  "ios": {
    "contentInset": "automatic"
  }
}
